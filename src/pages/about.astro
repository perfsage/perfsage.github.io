---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<BaseLayout
  title="About — PerfSage"
  description="Meet Aashish Bajpai: 9+ years in performance engineering, SRE, and reliability at VMware, EY, Oracle and more."
>
  <SiteNav />

  <main>
    <!-- ── Hero ─────────────────────────────────────────────── -->
    <header class="about-hero">
      <div class="container about-grid">

        <!-- Photo -->
        <div class="avatar-card" data-reveal>
          <img
            src="/images/aashish-bajpai.png"
            alt="Aashish Bajpai — Senior Performance Engineer"
            class="avatar-photo"
            width="160"
            height="160"
            loading="eager"
          />
        </div>

        <!-- Bio -->
        <div data-reveal>
          <div class="badge">
            <span class="pulse-dot" aria-hidden="true"></span>
            Senior Performance Engineer
          </div>
          <p class="role-title">SRE &middot; DevPerfOps &middot; Bengaluru, India</p>
          <h1 style="margin-top: 14px;">Aashish Bajpai</h1>
          <p class="about-tagline">
            9+ years turning test signals into SLO-grade confidence — at VMware, EY, Oracle &amp; beyond.
          </p>
          <div class="cta-row">
            <a
              class="btn btn-primary"
              href="https://topmate.io/abajpai/659595"
              target="_blank"
              rel="noopener noreferrer"
            >&#128197; Book a Call</a>
            <a
              class="btn btn-outline"
              href="https://thinkbits.org"
              target="_blank"
              rel="noopener noreferrer"
            >Blog / Resume &#10142;</a>
          </div>
        </div>
      </div>
    </header>

    <!-- ── Story ─────────────────────────────────────────────── -->
    <section class="section">
      <div class="container">
        <h2 class="section-title" data-reveal>My Story</h2>
        <div class="story">
          <div class="card" data-reveal>
            <p class="section-subtitle" style="margin-top: 0;">
              Full-stack performance and reliability engineer with ~9 years of expertise in performance
              optimisation, software development &amp; site reliability engineering. Problem solver, research
              oriented &amp; builder by attitude — able to own projects end-to-end and translate business
              requirements into mature solutions.
              <br /><br />
              At <strong>PerfSage</strong>, I build open-source tools and patterns that make performance
              engineering faster to execute and easier to understand. I also write at
              <a href="https://thinkbits.org" target="_blank" rel="noopener noreferrer" class="inline-link"
                >thinkbits.org</a
              >, sharing practical insights and battle-tested lessons from the field.
            </p>
          </div>

          <div class="card" data-reveal>
            <h3 class="card-heading">By the Numbers</h3>
            <div class="stats" style="margin-top: 14px;">
              <div class="stat-card">
                <div class="stat-number" data-counter data-target="9" data-suffix="+" data-mode="normal">0</div>
                <div class="stat-label">Years XP</div>
              </div>
              <div class="stat-card">
                <div class="stat-number" data-counter data-target="5" data-suffix="+" data-mode="normal">0</div>
                <div class="stat-label">Companies</div>
              </div>
              <div class="stat-card">
                <div class="stat-number" data-counter data-target="5" data-mode="normal" data-suffix="">0</div>
                <div class="stat-label">Certifications</div>
              </div>
              <div class="stat-card">
                <div class="stat-number" data-counter data-target="1" data-mode="infinity">0</div>
                <div class="stat-label">Incidents Learned</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Skills ─────────────────────────────────────────────── -->
    <section class="section">
      <div class="container">
        <h2 class="section-title" data-reveal>Technical Skills</h2>
        <div class="card skill-card" style="margin-top: 20px;">
          <div class="skill-row" data-skillbar data-progress="95" data-reveal>
            <div class="skill-head"><span>Apache JMeter</span><span>95%</span></div>
            <div class="progress"><div class="progress__bar" data-skillbar-bar></div></div>
          </div>
          <div class="skill-row" data-skillbar data-progress="93" data-reveal>
            <div class="skill-head"><span>API &amp; Load Performance Testing</span><span>93%</span></div>
            <div class="progress"><div class="progress__bar" data-skillbar-bar></div></div>
          </div>
          <div class="skill-row" data-skillbar data-progress="90" data-reveal>
            <div class="skill-head"><span>SRE / SLO / SLI Engineering</span><span>90%</span></div>
            <div class="progress"><div class="progress__bar" data-skillbar-bar></div></div>
          </div>
          <div class="skill-row" data-skillbar data-progress="88" data-reveal>
            <div class="skill-head"><span>Python &amp; Automation (Locust, Terraform)</span><span>88%</span></div>
            <div class="progress"><div class="progress__bar" data-skillbar-bar></div></div>
          </div>
          <div class="skill-row" data-skillbar data-progress="87" data-reveal>
            <div class="skill-head"><span>AWS &amp; Cloud Infrastructure</span><span>87%</span></div>
            <div class="progress"><div class="progress__bar" data-skillbar-bar></div></div>
          </div>
          <div class="skill-row" data-skillbar data-progress="85" data-reveal>
            <div class="skill-head"><span>Kubernetes &amp; Container Orchestration</span><span>85%</span></div>
            <div class="progress"><div class="progress__bar" data-skillbar-bar></div></div>
          </div>
          <div class="skill-row" data-skillbar data-progress="82" data-reveal>
            <div class="skill-head"><span>Chaos Engineering &amp; Fault Injection</span><span>82%</span></div>
            <div class="progress"><div class="progress__bar" data-skillbar-bar></div></div>
          </div>
          <div class="skill-row" data-skillbar data-progress="80" data-reveal>
            <div class="skill-head"><span>Observability (Datadog, Grafana, Prometheus)</span><span>80%</span></div>
            <div class="progress"><div class="progress__bar" data-skillbar-bar></div></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Experience Timeline ─────────────────────────────────── -->
    <section class="section">
      <div class="container">
        <h2 class="section-title" data-reveal>Experience Timeline</h2>

        <div class="timeline-list" data-reveal>

          <!-- VMware -->
          <div class="tl-item tl-current">
            <div class="tl-marker" aria-hidden="true">
              <span class="tl-dot"></span>
              <span class="tl-line"></span>
            </div>
            <div class="tl-content card">
              <div class="tl-header">
                <div>
                  <span class="tl-company">VMware</span>
                  <span class="tl-badge tl-badge--live">Current</span>
                </div>
                <span class="tl-period">Jun 2021 &ndash; Present &middot; Bengaluru</span>
              </div>
              <h3 class="tl-role">Senior Member of Technical Staff &mdash; SRE &amp; Dev</h3>
              <ul class="tl-bullets">
                <li>Led CDN migration from Imperva &#10132; AWS (CloudFront + WAF + Shield) &mdash; <strong>30% cost saving</strong>, 99.99% availability</li>
                <li>Performance &amp; chaos testing for a Kubernetes multi-tenant identity platform serving SSO across all VMware cloud</li>
                <li>Automated 200+ performance tests as-a-service; built Terraform scripts reducing manual infra ops by 80%</li>
              </ul>
            </div>
          </div>

          <!-- EY -->
          <div class="tl-item">
            <div class="tl-marker" aria-hidden="true">
              <span class="tl-dot"></span>
              <span class="tl-line"></span>
            </div>
            <div class="tl-content card">
              <div class="tl-header">
                <span class="tl-company">Ernst &amp; Young (EY)</span>
                <span class="tl-period">Dec 2020 &ndash; Jun 2021 &middot; Bengaluru</span>
              </div>
              <h3 class="tl-role">Site Reliability Engineer</h3>
              <ul class="tl-bullets">
                <li>Onboarded &amp; optimised performance for 15+ EY cloud-native microservices as SRE-as-a-Service</li>
                <li>Defined SLO/SLI &amp; error budgets; resolved 15+ production incidents as sole on-call engineer</li>
                <li>Built &ldquo;Synthetic Tests as a Service&rdquo; tool &mdash; reduced manual testing effort by 70%</li>
              </ul>
            </div>
          </div>

          <!-- Oracle -->
          <div class="tl-item">
            <div class="tl-marker" aria-hidden="true">
              <span class="tl-dot"></span>
              <span class="tl-line"></span>
            </div>
            <div class="tl-content card">
              <div class="tl-header">
                <span class="tl-company">Oracle</span>
                <span class="tl-period">May 2020 &ndash; Dec 2020 &middot; Bengaluru</span>
              </div>
              <h3 class="tl-role">Performance Engineer — OCI</h3>
              <ul class="tl-bullets">
                <li>Owned production performance &amp; reliability incidents for multiple Oracle Cloud Infrastructure services</li>
                <li>Leveraged data analytics to predict architecture/app issues from historical incident patterns</li>
                <li>Capacity planning for &ldquo;Chat Bot as a Service&rdquo; and blameless post-mortem process rollout</li>
              </ul>
            </div>
          </div>

          <!-- Infor -->
          <div class="tl-item">
            <div class="tl-marker" aria-hidden="true">
              <span class="tl-dot"></span>
              <span class="tl-line"></span>
            </div>
            <div class="tl-content card">
              <div class="tl-header">
                <span class="tl-company">Infor</span>
                <span class="tl-period">Aug 2018 &ndash; May 2020 &middot; Ahmedabad</span>
              </div>
              <h3 class="tl-role">Performance Engineer</h3>
              <ul class="tl-bullets">
                <li>Slashed BI dashboard load time from <strong>&gt;50 s to ~5 s</strong> through major architectural changes</li>
                <li>Built Ruby/JMeter framework for automated script generation; monitoring with Grafana, Datadog &amp; CloudWatch</li>
                <li>Reduced false positives in performance strategy, directly improving ROI and production predictability</li>
              </ul>
            </div>
          </div>

          <!-- Cavisson -->
          <div class="tl-item tl-last">
            <div class="tl-marker" aria-hidden="true">
              <span class="tl-dot"></span>
            </div>
            <div class="tl-content card">
              <div class="tl-header">
                <span class="tl-company">Cavisson Systems</span>
                <span class="tl-period">Mar 2016 &ndash; Aug 2018 &middot; Noida</span>
              </div>
              <h3 class="tl-role">Performance Engineer</h3>
              <ul class="tl-bullets">
                <li>Full-spectrum benchmarking: microservices, databases, messaging queues, app containers (JBoss, Tomcat)</li>
                <li>JVM tuning reduced average CPU by &gt;10%; UI performance optimisation for Macy's production (Akamai mPulse, IBM TeaLeaf)</li>
                <li>Resilience testing on AWS: Auto Scaling, Load Balancing, CloudFront — earned AWS SA Certification</li>
              </ul>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── Certifications ─────────────────────────────────────── -->
    <section class="section">
      <div class="container">
        <h2 class="section-title" data-reveal>Certifications</h2>
        <p class="section-subtitle" data-reveal>Verified credentials across cloud, infrastructure &amp; chaos engineering.</p>

        <div class="cert-grid" data-reveal>

          <a class="cert-card" href="https://www.certmetrics.com/amazon/public/transcript.aspx?transcript=FSH2XNQK1BB11PKW" target="_blank" rel="noopener noreferrer">
            <div class="cert-icon cert-aws" aria-hidden="true">AWS</div>
            <div class="cert-body">
              <strong>AWS Certified Solutions Architect</strong>
              <span class="cert-id">XZN3SVT1BER4Q63F</span>
            </div>
            <span class="cert-arrow" aria-hidden="true">&#10142;</span>
          </a>

          <a class="cert-card" href="https://www.youracclaim.com/badges/f1505f9b-c83f-4e90-bf8c-bed981da2793/public_url" target="_blank" rel="noopener noreferrer">
            <div class="cert-icon cert-azure" aria-hidden="true">Az</div>
            <div class="cert-body">
              <strong>Microsoft Azure Fundamentals</strong>
              <span class="cert-id">H650-5446</span>
            </div>
            <span class="cert-arrow" aria-hidden="true">&#10142;</span>
          </a>

          <a class="cert-card" href="https://www.credly.com/badges/7b80f0bc-a515-48e3-a7ab-5519a57b118a/public_url" target="_blank" rel="noopener noreferrer">
            <div class="cert-icon cert-tf" aria-hidden="true">Tf</div>
            <div class="cert-body">
              <strong>HashiCorp Terraform Associate</strong>
              <span class="cert-id">7b80f0bc&#8209;a515&#8209;48e3</span>
            </div>
            <span class="cert-arrow" aria-hidden="true">&#10142;</span>
          </a>

          <a class="cert-card" href="https://www.hackerrank.com/certificates/91c170b9ec76" target="_blank" rel="noopener noreferrer">
            <div class="cert-icon cert-hr" aria-hidden="true">HR</div>
            <div class="cert-body">
              <strong>HackerRank Java Developer</strong>
              <span class="cert-id">91C170B9EC76</span>
            </div>
            <span class="cert-arrow" aria-hidden="true">&#10142;</span>
          </a>

          <a class="cert-card" href="https://certification.gremlin.com/abf04395-36b7-4a42-94e3-705aed064647" target="_blank" rel="noopener noreferrer">
            <div class="cert-icon cert-gremlin" aria-hidden="true">GR</div>
            <div class="cert-body">
              <strong>Gremlin Certified Chaos Engineer</strong>
              <span class="cert-id">113322460</span>
            </div>
            <span class="cert-arrow" aria-hidden="true">&#10142;</span>
          </a>

        </div>
      </div>
    </section>

    <!-- ── Tools ──────────────────────────────────────────────── -->
    <section class="section">
      <div class="container">
        <h2 class="section-title" data-reveal>Tools I Use</h2>

        <div class="tool-grid" data-reveal>
          {[
            ['JM', 'JMeter', 'Load Testing'],
            ['Py', 'Python', 'Locust / Scripts'],
            ['k6', 'k6', 'Load Testing'],
            ['K8', 'Kubernetes', 'Orchestration'],
            ['Dk', 'Docker', 'Containers'],
            ['PG', 'PostgreSQL', 'Databases'],
            ['DD', 'Datadog', 'Observability'],
            ['GF', 'Grafana', 'Dashboards'],
            ['Pr', 'Prometheus', 'Metrics'],
            ['Tf', 'Terraform', 'IaC'],
            ['eB', 'eBPF', 'Kernel Tracing'],
            ['Li', 'Linux', 'Systems'],
          ].map(([code, name, sub]) => (
            <div class="tool-tile">
              <svg viewBox="0 0 64 64" aria-hidden="true">
                <defs>
                  <linearGradient id={'g-' + code.toLowerCase()} x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0" stop-color="#7c6af7" />
                    <stop offset="1" stop-color="#00d4aa" />
                  </linearGradient>
                </defs>
                <rect x="8" y="8" width="48" height="48" rx="16" fill="rgba(255,255,255,0.04)" stroke="rgba(124,106,247,0.3)" />
                <rect x="8" y="8" width="48" height="48" rx="16" fill={'url(#g-' + code.toLowerCase() + ')'} opacity="0.2" />
                <text x="32" y="40" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="18" font-weight="800" fill="currentColor">{code}</text>
              </svg>
              <div><b>{name}</b><div class="tiny-muted">{sub}</div></div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  /* ── Photo ─────────────────────────────────────── */
  .avatar-photo {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 3px solid rgba(124, 106, 247, 0.4);
    box-shadow: 0 0 40px rgba(124, 106, 247, 0.25);
    display: block;
    margin: 0 auto;
  }

  /* ── Timeline ──────────────────────────────────── */
  .timeline-list {
    margin-top: 20px;
    display: grid;
    gap: 0;
  }

  .tl-item {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 0 16px;
  }

  .tl-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 22px;
  }

  .tl-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--primary);
    border: 2px solid var(--bg);
    box-shadow: 0 0 0 3px rgba(124, 106, 247, 0.3);
    flex-shrink: 0;
    z-index: 1;
  }

  .tl-current .tl-dot {
    background: var(--teal);
    box-shadow: 0 0 0 3px rgba(0, 212, 170, 0.3);
    animation: pulse-tl 2s ease-in-out infinite;
  }

  @keyframes pulse-tl {
    0%, 100% { box-shadow: 0 0 0 3px rgba(0, 212, 170, 0.3); }
    50% { box-shadow: 0 0 0 7px rgba(0, 212, 170, 0.1); }
  }

  .tl-line {
    flex: 1;
    width: 2px;
    background: linear-gradient(to bottom, rgba(124, 106, 247, 0.4), rgba(124, 106, 247, 0.08));
    margin-top: 4px;
    min-height: 20px;
  }

  .tl-content {
    margin-bottom: 16px;
  }

  .tl-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    justify-content: space-between;
    margin-bottom: 4px;
  }

  .tl-company {
    font-size: 1.08rem;
    font-weight: 700;
    color: var(--primary);
    letter-spacing: -0.01em;
  }

  .tl-period {
    font-size: 0.82rem;
    color: var(--muted-2);
    font-family: 'JetBrains Mono', monospace;
    white-space: nowrap;
  }

  .tl-role {
    font-size: 0.97rem;
    font-weight: 600;
    color: var(--text);
    margin: 4px 0 10px;
  }

  .tl-badge {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 999px;
    background: rgba(0, 212, 170, 0.12);
    color: var(--teal);
    border: 1px solid rgba(0, 212, 170, 0.3);
  }

  .tl-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 6px;
  }

  .tl-bullets li {
    font-size: 0.88rem;
    color: var(--muted);
    padding-left: 18px;
    position: relative;
    line-height: 1.55;
  }

  .tl-bullets li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--primary);
    font-size: 0.75rem;
    top: 2px;
  }

  /* ── Certifications ──────────────────────────── */
  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
    margin-top: 20px;
  }

  .cert-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    background: var(--panel);
    border: 1px solid var(--stroke);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .cert-card:hover {
    border-color: rgba(124, 106, 247, 0.45);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.22);
  }

  .cert-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 800;
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .cert-aws { background: rgba(255, 153, 0, 0.14); color: #ff9900; border: 1px solid rgba(255, 153, 0, 0.3); }
  .cert-azure { background: rgba(0, 114, 198, 0.14); color: #0072C6; border: 1px solid rgba(0, 114, 198, 0.3); }
  .cert-tf { background: rgba(124, 56, 255, 0.14); color: #7B42BC; border: 1px solid rgba(124, 56, 255, 0.3); }
  .cert-hr { background: rgba(0, 212, 170, 0.12); color: var(--teal); border: 1px solid rgba(0, 212, 170, 0.28); }
  .cert-gremlin { background: rgba(255, 75, 75, 0.12); color: #ff6b6b; border: 1px solid rgba(255, 75, 75, 0.28); }

  .cert-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .cert-body strong {
    font-size: 0.9rem;
    font-weight: 700;
  }

  .cert-id {
    font-size: 0.73rem;
    font-family: 'JetBrains Mono', monospace;
    color: var(--muted-2);
    letter-spacing: 0.03em;
  }

  .cert-arrow {
    color: var(--primary);
    opacity: 0.7;
    font-size: 0.85rem;
    flex-shrink: 0;
  }
</style>
