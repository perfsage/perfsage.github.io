---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<BaseLayout
  title="Contact — PerfSage"
  description="Contact Aashish Bajpai for consulting, mentorship, and open-source reliability engagements."
>
  <SiteNav />

  <main>
    <header class="hero">
      <div class="container hero-inner">
        <div class="badge" data-reveal>
          <span class="pulse-dot" aria-hidden="true"></span>
          Let&rsquo;s Connect
        </div>
        <h1 data-reveal>
          Let&rsquo;s Build Something <span class="gradient-text">Fast</span> Together
        </h1>
        <p class="hero-subtitle" data-reveal>
          Reach out for performance consulting, mentorship, open-source collaboration, or reliability engineering
          engagements.
        </p>
        <div class="availability" data-reveal>
          &#x25CF;&nbsp; Currently available for consulting &amp; mentorship engagements
        </div>
      </div>
    </header>

    <section class="section">
      <div class="container">
        <div class="contact-grid">

          <!-- Social links -->
          <div data-reveal>
            <h2 class="section-title">Find Me Online</h2>

            <div class="card" style="margin-top: 14px; display: grid; gap: 10px;">
              <div class="contact-card">
                <div style="display:flex;align-items:center;gap:12px;">
                  <span class="contact-icon" aria-hidden="true">&#9889;</span>
                  <strong>GitHub</strong>
                </div>
                <a href="https://github.com/perfsage" target="_blank" rel="noopener noreferrer">github.com/perfsage</a>
              </div>

              <div class="contact-card">
                <div style="display:flex;align-items:center;gap:12px;">
                  <span class="contact-icon" aria-hidden="true">in</span>
                  <strong>LinkedIn</strong>
                </div>
                <a href="https://linkedin.com/in/aashu320" target="_blank" rel="noopener noreferrer">linkedin.com/in/aashu320</a>
              </div>

              <div class="contact-card">
                <div style="display:flex;align-items:center;gap:12px;">
                  <span class="contact-icon" aria-hidden="true">&#120143;</span>
                  <strong>Twitter / X</strong>
                </div>
                <a href="https://x.com/aashu320" target="_blank" rel="noopener noreferrer">x.com/aashu320</a>
              </div>

              <div class="contact-card">
                <div style="display:flex;align-items:center;gap:12px;">
                  <span class="contact-icon" aria-hidden="true">&#128197;</span>
                  <strong>Book a Call (Topmate)</strong>
                </div>
                <a href="https://topmate.io/abajpai/659595" target="_blank" rel="noopener noreferrer">topmate.io/abajpai</a>
              </div>

              <div class="contact-card">
                <div style="display:flex;align-items:center;gap:12px;">
                  <span class="contact-icon" aria-hidden="true">&#128221;</span>
                  <strong>Blog</strong>
                </div>
                <a href="https://thinkbits.org" target="_blank" rel="noopener noreferrer">thinkbits.org</a>
              </div>
            </div>
          </div>

          <!-- Email form -->
          <div class="card" data-reveal>
            <h2 class="section-title">Send a Message</h2>
            <p class="section-subtitle" style="margin-top: 8px;">
              Write your message below and hit send &mdash; your email client will open with everything pre-filled.
            </p>

            <div class="field" style="margin-top: 20px;">
              <label for="contact-message">Your Message</label>
              <textarea
                id="contact-message"
                name="message"
                placeholder="Tell me what you're building and what success looks like..."
              ></textarea>
            </div>

            <div class="field">
              <label for="contact-subject">Subject <span style="color:var(--muted-2);font-weight:400;">(optional, defaults to &ldquo;PerfSage Query&rdquo;)</span></label>
              <input
                id="contact-subject"
                name="subject"
                type="text"
                placeholder="PerfSage Query"
              />
            </div>

            <div class="form-actions">
              <button
                id="send-email-btn"
                class="btn btn-primary btn-submit"
                type="button"
                aria-label="Open in Email Client"
              >
                &#9993; Open in Email Client
              </button>
            </div>

            <p class="send-hint">
              Sends to <code>aashish.bajpai2@gmail.com</code> via your default email app.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<script is:inline>
  (function () {
    var btn = document.getElementById('send-email-btn');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var msg = (document.getElementById('contact-message').value || '').trim();
      var subj = (document.getElementById('contact-subject').value || '').trim() || 'PerfSage Query';
      var mailto = 'mailto:aashish.bajpai2@gmail.com'
        + '?subject=' + encodeURIComponent(subj)
        + (msg ? '&body=' + encodeURIComponent(msg) : '');
      window.location.href = mailto;
    });
  })();
</script>

<style>
  .send-hint {
    margin-top: 12px;
    font-size: 0.8rem;
    color: var(--muted-2);
  }

  .send-hint code {
    font-family: 'JetBrains Mono', monospace;
    color: var(--teal);
    font-size: 0.78rem;
  }
</style>
