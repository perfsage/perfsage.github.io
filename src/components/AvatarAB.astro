---
interface Props {
  size?: number;
}

const { size = 150 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 160 160"
  role="img"
  aria-label="Avatar placeholder AB"
  class="avatar-ab"
>
  <defs>
    <linearGradient id="g1" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#7c6af7" stop-opacity="0.95" />
      <stop offset="1" stop-color="#00d4aa" stop-opacity="0.9" />
    </linearGradient>
  </defs>
  <circle cx="80" cy="80" r="72" fill="rgba(255,255,255,0.04)" stroke="rgba(124,106,247,0.35)" stroke-width="3" />
  <circle cx="80" cy="80" r="62" fill="url(#g1)" opacity="0.22" />
  <text
    x="80"
    y="92"
    text-anchor="middle"
    font-family="JetBrains Mono, ui-monospace, monospace"
    font-size="46"
    font-weight="700"
    fill="currentColor"
  >
    AB
  </text>
</svg>

